From 77dd022f355eeded69873800a7557842a45e61db Mon Sep 17 00:00:00 2001
From: whitebelyash <whbexiumwork@gmail.com>
Date: Fri, 16 Jan 2026 22:45:16 +0400
Subject: [PATCH 04/12] HACK: freedreno: force initial gmem offset only for 2+
 slice GPUs

On A810 this additional offset caused integer underflows because the remaining number was very small due to size of A810 GMEM cache (576K)

Signed-off-by: whitebelyash <whbexiumwork@gmail.com>
---
 src/freedreno/common/fd6_gmem_cache.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/freedreno/common/fd6_gmem_cache.h b/src/freedreno/common/fd6_gmem_cache.h
index c2243d3cb25..560890630f0 100644
--- a/src/freedreno/common/fd6_gmem_cache.h
+++ b/src/freedreno/common/fd6_gmem_cache.h
@@ -43,7 +43,7 @@ __calc_gmem_cache_offsets(const struct fd_dev_info *info, unsigned offset,
    unsigned num_ccu = info->num_ccu;
 
    /* This seems not to be load bearing, but keeping it for now to match blob: */
-   if (info->chip >= 8)
+   if (info->chip >= 8 && info->num_slices > 1)
       offset -= 0x78000;
 
    config->vpc_bv_pos_buf_offset = offset - (num_ccu * config->vpc_bv_pos_buf_size);
-- 
